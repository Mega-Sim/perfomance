{
  "spec_version": "1.1",
  "dataset": {
    "paths": {
      "images_dir": "datasets/standard/images",
      "graphs_dir": "datasets/standard/graphs",
      "previews_dir": "datasets/standard/previews",
      "manifest_path": "datasets/standard/manifest.jsonl",
      "labels_path_optional": "datasets/standard/labels.jsonl"
    },
    "file_naming": {
      "allowed_extensions": [
        ".png"
      ],
      "recommended_stem_regex": "^[0-9]{4,6}$"
    }
  },
  "image": {
    "canvas": {
      "recommended_min_size_px": [
        256,
        256
      ],
      "recommended_max_size_px": [
        2048,
        2048
      ],
      "background": {
        "rgb": [
          255,
          255,
          255
        ],
        "tolerance_per_channel": 25,
        "recommended_background_ratio_min": 0.7
      }
    },
    "track": {
      "color": {
        "mode": "green_dominant",
        "min_g": 120,
        "min_g_minus_r": 20,
        "min_g_minus_b": 20
      }
    },
    "node_marker": {
      "required": true,
      "shape": "circle dot",
      "color": {
        "mode": "red_dominant",
        "min_r": 140,
        "min_r_minus_g": 40,
        "min_r_minus_b": 40
      }
    },
    "station_marker": {
      "required": false,
      "shape": "square dot",
      "color": {
        "mode": "blue_dominant",
        "min_b": 140,
        "min_b_minus_r": 40,
        "min_b_minus_g": 40
      }
    },
    "direction_marker": {
      "required": true,
      "type": "arrow",
      "color": "black_or_dark",
      "placement_rule": "outside_track",
      "legacy_phase1_mask_class": "arrow_black"
    }
  },
  "phase1": {
    "color_thresholds": {
      "background": {
        "lo": [
          230,
          230,
          230
        ],
        "hi": [
          255,
          255,
          255
        ]
      },
      "track_green": {
        "lo": [
          0,
          120,
          0
        ],
        "hi": [
          100,
          255,
          100
        ]
      },
      "split_red": {
        "lo": [
          140,
          0,
          0
        ],
        "hi": [
          255,
          100,
          100
        ]
      },
      "merge_purple": {
        "lo": [
          120,
          0,
          120
        ],
        "hi": [
          255,
          140,
          255
        ]
      },
      "station_blue": {
        "lo": [
          0,
          0,
          140
        ],
        "hi": [
          100,
          100,
          255
        ]
      },
      "arrow_black": {
        "lo": [
          0,
          0,
          0
        ],
        "hi": [
          70,
          70,
          70
        ]
      }
    }
  }
}